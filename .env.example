# HarnessFit
# Copy this to .env and fill in your API keys
# Or use direnv: cp .env.example .envrc && direnv allow

# Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# Optional: override default model identifiers
# HARNESSFIT_OPENAI_MODEL=gpt-5.6-luna
# HARNESSFIT_ANTHROPIC_MODEL=claude-haiku-4-5
# HARNESSFIT_GOOGLE_MODEL=gemini-3.5-flash

# Optional: log level (debug, info, warn, error)
# HARNESSFIT_LOG_LEVEL=info
